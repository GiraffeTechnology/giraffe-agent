# market-reference-pricing environment variables
# Copy to .env.market-reference and fill in all required values
# NEVER commit .env.market-reference to version control

# ============================================================
# DashScope / Qwen API (for structured field extraction only)
# Get your key from: https://dashscope.aliyuncs.com
# ============================================================
DASHSCOPE_API_KEY=your-dashscope-api-key-here
QWEN_EXTRACTION_MODEL=qwen-long
QWEN_MIN_CONFIDENCE=0.80

# ============================================================
# Database (isolated from main giraffe-agent DB)
# ============================================================
DB_USER=mrp_user
DB_PASSWORD=your-secure-password-here
DATABASE_URL=postgresql://mrp_user:your-secure-password-here@postgres:5432/market_reference_db

# ============================================================
# 1688 Open Platform API credentials
# Apply at: https://open.1688.com
# Required before automated data collection can begin
# ============================================================
ALIBABA_1688_APP_KEY=
ALIBABA_1688_APP_SECRET=
ALIBABA_1688_ACCESS_TOKEN=

# ============================================================
# Scraping configuration
# ============================================================
SCRAPE_RATE_LIMIT_PER_MINUTE=5
SCRAPE_USER_AGENT=GiraffePricingResearch/1.0 (market-reference-pricing; contact: michael@giraffetechnology.io)

# ============================================================
# Storage paths
# ============================================================
HTML_SNAPSHOT_DIR=/data/snapshots
LOG_DIR=/data/logs
LOG_LEVEL=INFO
