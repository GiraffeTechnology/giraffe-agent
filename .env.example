# Giraffe Agent / AIVAN — Environment Configuration
#
# Copy this file to .env and fill in values as needed.
# Most settings are optional. AIVAN runs in mock mode without any credentials.
#
# cp .env.example .env

# ─── Database ─────────────────────────────────────────────────────────────────

# Database mode: "off" = in-memory / file-based (default), "on" = SQLAlchemy DB
GIRAFFE_DB_MODE=off

# SQLAlchemy database URL (required when GIRAFFE_DB_MODE=on)
# Default: SQLite local file
# GIRAFFE_DB_URL=sqlite:///./giraffe_agent.db

# ─── LLM Integration (optional) ───────────────────────────────────────────────

# Qwen (Alibaba DashScope) — used by QC Intelligence for media comparison
# Without this key, AIVAN runs in mock mode with rule-based responses
# DASHSCOPE_API_KEY=your-dashscope-api-key-here
# QWEN_API_KEY=your-qwen-api-key-here

# ─── AIVAN Service ────────────────────────────────────────────────────────────

# Base URL for the AIVAN service (used by the OpenClaw plugin bridge)
# This is the URL other services use to reach AIVAN
# Default: http://localhost:8000
# AIVAN_BASE_URL=http://localhost:8000

# Optional API key to protect the AIVAN REST API
# If set, requests must include X-AIVAN-API-Key header
# AIVAN_API_KEY=your-optional-aivan-api-key-here

# ─── OpenClaw (optional) ──────────────────────────────────────────────────────

# OpenClaw channel credentials are managed by the OpenClaw runtime, NOT by AIVAN.
# Do not put IM platform tokens (WeChat, WhatsApp, etc.) here.
# AIVAN only receives normalized events from OpenClaw — never raw channel tokens.
