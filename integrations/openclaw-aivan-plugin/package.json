{
  "name": "@giraffetechnology/openclaw-aivan",
  "version": "0.1.0",
  "type": "module",
  "description": "OpenClaw plugin bridge for AIVAN, a local-first AI trade salesperson assistant by Giraffe Technology",
  "main": "index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/GiraffeTechnology/giraffe-agent"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18.0.0"
  },
  "openclaw": {
    "extensions": ["./index.ts"],
    "runtimeExtensions": ["./dist/index.js"],
    "compat": {
      "pluginApi": "1.0"
    },
    "build": {
      "openclawVersion": ">=2026.3.22"
    }
  },
  "keywords": [
    "openclaw",
    "clawhub",
    "aivan",
    "trade",
    "procurement",
    "salesperson",
    "giraffe-technology"
  ],
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3"
  }
}
