# Giraffe Agent / AIVAN — Environment Configuration
#
# Copy this file to .env and fill in values as needed.
# Most settings are optional. AIVAN runs in mock mode without any credentials.
#
# cp .env.example .env

# ─── Database ─────────────────────────────────────────────────────────────────

# Database mode: "off" = in-memory / file-based (default), "on" = SQLAlchemy DB
GIRAFFE_DB_MODE=off

# SQLAlchemy database URL (required when GIRAFFE_DB_MODE=on)
# Default: SQLite local file
# GIRAFFE_DB_URL=sqlite:///./giraffe_agent.db

# Used by alembic and src/db/config.py
# DATABASE_URL=sqlite:///./giraffe_mvp.db

# ─── LLM Integration ──────────────────────────────────────────────────────────

# Qwen (Alibaba DashScope) — primary LLM for AIVAN
# [REQUIRED for real Qwen calls] Replace <PLACEHOLDER> with your actual key.
# The key is NEVER printed in logs or test output.
# Get your key from: https://dashscope.console.aliyun.com/
# DASHSCOPE_API_KEY=<PLACEHOLDER>
# QWEN_API_KEY=<PLACEHOLDER>

# Optional: override model names (defaults shown)
# QWEN_TEXT_MODEL=qwen-turbo
# QWEN_VISION_MODEL=qwen-vl-plus
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/api/v1

# Set to true to enable real Qwen API calls in tests (default: false → mock)
# LLM_ENABLE_REAL_CALLS=true

# LLM timeout / retry
# LLM_TIMEOUT_SECONDS=60
# LLM_MAX_RETRIES=2

# ─── E2E Integration Test Control ─────────────────────────────────────────────

# Set to 'real' for full real-API E2E (requires QWEN_API_KEY above).
# Set to 'mock' to run E2E with mocked Qwen (GLTG and DB are always real).
# E2E_QWEN_MODE=real

# Path to the giraffe-mcp-server-demo repository (for fixture data).
# DEMO_REPO_PATH=/home/user/giraffe-mcp-server-demo

# ─── AIVAN Service ────────────────────────────────────────────────────────────

# Base URL for the AIVAN service (used by the OpenClaw plugin bridge)
# Default: http://localhost:8000
# AIVAN_BASE_URL=http://localhost:8000

# Optional API key to protect the AIVAN REST API
# AIVAN_API_KEY=your-optional-aivan-api-key-here

# ─── OpenClaw (optional) ──────────────────────────────────────────────────────

# OpenClaw channel credentials are managed by the OpenClaw runtime, NOT by AIVAN.
# Do not put IM platform tokens (WeChat, WhatsApp, etc.) here.
# AIVAN only receives normalized events from OpenClaw — never raw channel tokens.
